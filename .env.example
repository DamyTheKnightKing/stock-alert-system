# Email Notifications (Gmail SMTP — free)
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_password_here   # Gmail App Password (not your account password)
EMAIL_RECIPIENTS=recipient1@gmail.com,recipient2@gmail.com

# Optional: Alpha Vantage (free tier: 25 req/day)
ALPHA_VANTAGE_API_KEY=your_key_here

# Storage (SQLite by default — zero setup, zero cost)
# To use PostgreSQL/Supabase instead, set this:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///data/stock_alerts.db
