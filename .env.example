# Email Notifications via Resend (resend.com — free tier: 3,000 emails/month)
RESEND_API_KEY=re_your_api_key_here
EMAIL_RECIPIENTS=recipient1@gmail.com,recipient2@gmail.com

# Storage (SQLite by default — zero setup, zero cost)
# To use PostgreSQL/Supabase instead, set this:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Turso (recommended — free, persistent, never pauses)
DATABASE_URL=libsql+https://your-db-name.aws-ap-south-1.turso.io?authToken=your_turso_token

# SQLite fallback (local only — data resets in GitHub Actions)
# DATABASE_URL=sqlite:///data/stock_alerts.db

# Data source: yfinance (Yahoo Finance) — free, no API key needed

# ── v2 — News enrichment ─────────────────────────────────────────────────────
# NewsAPI — get free key at https://newsapi.org (100 req/day free)
NEWS_API_KEY=your_newsapi_key

# ── v3 — AI Commentary via OpenRouter (FREE — replaces Gemini billing) ────────
# Get free key at: https://openrouter.ai/keys
# AI commentary is automatically added to top picks in the morning digest
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Best free model for financial analysis: google/gemma-3-27b-it:free
OPENROUTER_STOCK_MODEL=google/gemma-3-27b-it:free
