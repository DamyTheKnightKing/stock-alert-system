@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

HIDE_STEREOTYPE()

title Stock Alert System — Architecture Overview

Person(subscriber, "Subscriber", "Investor who wants\npersonalized stock alerts")

System_Boundary(platform, "Stock Alert Platform") {

    Container(form, "Signup Form", "GitHub Pages", "Choose stocks to watch\nand preferred schedule")

    Container(api, "API Backend", "FastAPI · Render.com", "Handles subscriptions,\nunsubscribes, and stock search")

    ContainerDb(db, "Database", "Turso · libSQL Cloud", "Stores subscribers,\nprice snapshots, and alerts")

    Container(engine, "Alert Engine", "GitHub Actions · Python", "Scheduled twice daily —\nanalyses all watched symbols,\ndetects trading signals,\nbuilds personalised digest")

}

System_Ext(market, "Yahoo Finance", "Free real-time and\nhistorical market data")

System_Ext(email, "Resend", "Transactional email\ndelivery service")

Rel_R(subscriber, form, "Signs up · picks watchlist")
Rel_D(form, api, "POST /subscribe")
Rel_D(api, db, "Save / update subscriber")

Rel_L(engine, market, "Fetch price data")
Rel_R(engine, db, "Read subscribers\nWrite alerts")
Rel_D(engine, email, "Send digest")
Rel_U(email, subscriber, "Personalised email\nwith top picks & signals")

SHOW_LEGEND()

@enduml
